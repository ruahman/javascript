{
  "name": "ts_tut",
  "type": "module",
  "version": "1.0.0",
  "description": "typescript tutorial",
  "scripts": {
    "build": "tsc --module nodenext",
    "check": "tsc --noEmit --esModuleInterop",
    "watch": "tsc --watch",
    "exec": "node --no-warnings=ExperimentalWarning --experimental-transform-types",
    "exec:tsx": "tsx",
    "test": "node --no-warnings=ExperimentalWarning --experimental-transform-types --test",
    "test:tsx": "node --import tsx --test",
    "test:tsx:debug": "node --import tsx --inspect-brk --test",
    "debug": "node --inspect-brk",
    "lint": "eslint",
    "clean": "rimraf dist && rimraf node_modules && rimraf --glob src/*.d.ts"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.19.7",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0"
  }
}
