// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "adapter": "JavaScript",
    "label": "Debug TypeScript (tsx)",
    "type": "node",
    "request": "launch",
    "runtimeArgs": ["--import", "tsx"],
    "program": "$ZED_FILE",
    "skipFiles": ["<node_internals>/**"],
  },
]
